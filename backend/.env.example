# ==============================================================================
# Backend Configuration
# ==============================================================================
APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=mysql+pymysql://USER:PASSWORD@localhost:3306/ai_papers
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENABLE_SCHEDULER=false
TIMEZONE=Asia/Bangkok

# Agent Base URLs
TREND_AGENT_URL=http://127.0.0.1:8005
QA_AGENT_URL=http://127.0.0.1:8103
TTS_AGENT_URL=http://127.0.0.1:8104

# Agent Execution Modes
# Options: mock_fallback | real (requires Ollama)
QA_MODE=mock_fallback
# Options: mock_fallback | real (requires GPU or CPU-heavy TTS model)
TTS_MODE=mock_fallback

# Q&A Agent - Ollama LLM Settings (required when QA_MODE=real)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:4b

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=change_me
SMTP_FROM_EMAIL=your_email@example.com
SMTP_FROM_NAME=AI Papers Daily
SMTP_USE_TLS=true

# Storage Configuration
DATA_DIR=../data
STATIC_DATA_URL=/static/data

# PDF Download Configuration
ENABLE_PDF_DOWNLOAD=true
PDF_DOWNLOAD_TIMEOUT_SECONDS=30
MAX_PDF_SIZE_MB=50

