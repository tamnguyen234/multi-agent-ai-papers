# ==============================================================================
# AI Paper Multi-Agent System - Environment Configurations
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend Configuration
# ------------------------------------------------------------------------------
APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=mysql+pymysql://USER:PASSWORD@localhost:3306/ai_papers
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENABLE_SCHEDULER=false
TIMEZONE=Asia/Bangkok

# ------------------------------------------------------------------------------
# Agent Base URLs
# ------------------------------------------------------------------------------
SUMMARIZER_AGENT_URL=http://127.0.0.1:8101
TREND_AGENT_URL=http://127.0.0.1:8102
QA_AGENT_URL=http://127.0.0.1:8103
TTS_AGENT_URL=http://127.0.0.1:8104

# ------------------------------------------------------------------------------
# Agent Execution Modes
# ------------------------------------------------------------------------------
SUMMARIZER_MODE=mock_fallback
ARXIV_CATEGORIES=cs.AI,cs.CL,cs.LG,cs.CV,cs.RO,cs.SD
ARXIV_MAX_RESULTS=50
ARXIV_DAYS_BACK=2
SUMMARY_MAX_SENTENCES=3
SUMMARY_MAX_CHARS=700
TREND_MODE=rule_based_fallback
TREND_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TREND_MIN_TOPIC_SIZE=2
TREND_TOP_N_WORDS=8
TREND_UMAP_N_NEIGHBORS=5
TREND_UMAP_N_COMPONENTS=5
TREND_HDBSCAN_MIN_CLUSTER_SIZE=2
QA_MODE=mock_fallback
TTS_MODE=mock_fallback

# ------------------------------------------------------------------------------
# SMTP Configuration
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=change_me
SMTP_FROM_EMAIL=your_email@example.com
SMTP_FROM_NAME=AI Papers Daily
SMTP_USE_TLS=true

# ------------------------------------------------------------------------------
# Storage Directory Config
# ------------------------------------------------------------------------------
DATA_DIR=../data
STATIC_DATA_URL=/static/data

# PDF Download Configuration
ENABLE_PDF_DOWNLOAD=true
PDF_DOWNLOAD_TIMEOUT_SECONDS=30
MAX_PDF_SIZE_MB=50
